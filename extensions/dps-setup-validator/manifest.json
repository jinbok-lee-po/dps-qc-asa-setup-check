{
  "manifest_version": 3,
  "name": "DPS 커머스 운영안 검증",
  "version": "0.6.2",
  "description": "Woowa Portal DPS 커머스 automatic-assignment — Vendor group filters (Vertical type, Vendor ids, Delivery types) 검증.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["https://portal.woowahan.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://portal.woowahan.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
